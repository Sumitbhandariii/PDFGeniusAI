{
  "expo": {
    "name": "onspace-app",
    "slug": "pdf-genius-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "48ad8ca1-7c3c-4d12-90c3-d15985e20248"
      }
    },
    "android": {
      "package": "com.techeditz8.pdfgeniusai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://pdf-genius-ai.expo.app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/images/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  }
}
